# 项目基础设置
ENV=development
LOG_LEVEL=DEBUG

# 数据库相关配置
SQLALCHEMY_DATABASE_URL=

# redis相关配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 腾讯云COS配置
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_SCHEME=https
COS_BUCKET_NAME=
COS_DOMAIN=

# jwt配置
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_TIME=604800 # 7天
